# 多源勘察数据融合系统 —— 环境变量示例
#
# 复制为 .env 后按需修改。所有变量前缀 FUSION_。

# ---- 应用 ----
FUSION_ENV=dev
FUSION_HOST=0.0.0.0
FUSION_PORT=8000
FUSION_CORS_ORIGINS=["*"]

# ---- 路径（默认自动推断，通常无需设置）----
# FUSION_PROJECT_ROOT=
# FUSION_DATA_DIR=
# FUSION_FRONTEND_DIR=

# ---- 数据库 ----
# 离线兜底：设为 false，纯文件模式（兼容旧 run.bat）
# 完整模式：设为 true，启用 PostgreSQL + PostGIS
FUSION_USE_DB=false
FUSION_DATABASE_URL=postgresql+psycopg://fusion:fusion@localhost:5432/fusion
# 无 Docker/PG 时也可用 SQLite 演示 DB 模式（先跑 python -m backend.scripts.seed）：
# FUSION_DATABASE_URL=sqlite:///backend/data/fusion_demo.db
# DB 不可达或未装载时自动回退文件模式，演示不翻车。
FUSION_PG_ECHO=false
